\par}
{\tc\tcl2 \v Examples}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf21 #include <stdint.h>}\par
{\cf21 #include <stdbool.h>}\par
{\cf21 #include <stepper.h>}\par
{\cf21 #include <i2c.h>}\par
\par
uint8_t *{\field {\*\fldinst { HYPERLINK  \\l "AAAAAAAAAT" }{}}{\fldrslt {\cs37\ul\cf2 convDecByteToHex}}}
(uint8_t {\cf18 byte});\par
uint8_t vmax;\par
uint8_t addr = 0xC2;    {\cf20 // Schreibadresse des Motors}\par
uint8_t geschw = 0x00;  {\cf20 // 0x0 bis 0xF}\par
\par
{\cf18 int} {\field {\*\fldinst { HYPERLINK  \\l "AAAAAAAASQ" }{}}{\fldrslt {\cs37\ul\cf2 main}}}
({\cf18 void})\par
\{\par
    \par
    {\cf20 //StepL.init(...                        iRun,   iHold,  vMin,   vMax,   stepMode, rotDir, acceleration, securePosition)}\par
    {\field {\*\fldinst { HYPERLINK  \\l "AAAAAAAAGN" }{}}{\fldrslt {\cs37\ul\cf2 StepperInit}}}
(&{\field {\*\fldinst { HYPERLINK  \\l "AAAAAAAASV" }{}}{\fldrslt {\cs37\ul\cf2 StepL}}}
, i2c, {\field {\*\fldinst { HYPERLINK  \\l "AAAAAAAASM" }{}}{\fldrslt {\cs37\ul\cf2 i2cAddr_motL}}}
,  14,     1,      2,      14,         3,          1,      6,           0);\par
    \par
    \par
{\cf20 // ab hier umstellen auf struct amis.c}\par
    {\cf20 /* Hauptprogramm: Endlosschleife */}\par
    {\cf19 while}(1)\par
    \{\par
        {\cf19 for}({\cf18 int} i = 0; i < 500; ++i )\par
        \{\par
        {\cf18 int} ac_pos = getActualPosition(0xC2); {\cf20 // Auslesen der aktuellen Motorposition}\par
        setPosition(addr,  ac_pos+32767);\par
\par
        \}\par
        softStop(0xc2);         {\cf20 // Stoppt den Aktuellen Befehl}\par
\par
        setVmax(addr, geschw); {\cf20 // Stetzt die Geschwindigkeit des Steppers}\par
        geschw++;\par
\par
        {\cf19 if}(geschw == 0xf)\par
        \{\par
            geschw = 0x00;\par
        \}\par
    \}\par
    {\cf19 return} 0;\par
\}\par
}
\par}
